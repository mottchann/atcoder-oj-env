{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AtCoder: Test Current File",
      "type": "shell",
      "command": "uv run oj t -c \"uv run python ${fileBasename}\"",
      "options": {
        "cwd": "${fileDirname}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "AtCoder: Submit Current File",
      "type": "shell",
      "command": "acc submit ${fileBasename}",
      "options": {
        "cwd": "${fileDirname}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}